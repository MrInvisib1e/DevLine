#!/usr/bin/env bash
# Devline post-checkout: sync memory on branch switch
# Only fires on branch switch (flag=1), not file checkout (flag=0)

# $3 = branch flag: 1 = branch switch, 0 = file checkout
[[ "${3:-0}" == "1" ]] || exit 0

DEVLINE_DIR="$(git rev-parse --show-toplevel 2>/dev/null)/.devline"
[ -d "$DEVLINE_DIR" ] || exit 0

(
  sleep 0.1
  dl-init --write-memory > /dev/null 2>&1
  HEAD=$(git rev-parse HEAD 2>/dev/null || echo "unknown")
  python3 -c "
import json
cfg = '$DEVLINE_DIR/config.json'
try:
    c = json.load(open(cfg))
    c['last_synced'] = '$HEAD'
    json.dump(c, open(cfg, 'w'), indent=2)
except:
    pass
" 2>/dev/null
) &

exit 0
