#!/usr/bin/env bash
# DevFlow SessionStart hook for Claude Code / Cursor
# Injects the using-devflow bootstrap skill into session context

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
SKILL_FILE="${PLUGIN_ROOT}/skills/using-devflow/SKILL.md"

# Read bootstrap skill content
if [[ ! -f "$SKILL_FILE" ]]; then
  skill_content="DevFlow: bootstrap skill not found at ${SKILL_FILE}"
else
  skill_content=$(cat "$SKILL_FILE" 2>&1)
fi

# Fast JSON string escaping using bash parameter substitution (no python3 needed)
escape_for_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

escaped=$(escape_for_json "$skill_content")
session_context="<DEVFLOW_ACTIVE>\n${escaped}\n</DEVFLOW_ACTIVE>"

# Output format differs by platform:
# Claude Code sets CLAUDE_PLUGIN_ROOT
# Cursor sets CURSOR_PLUGIN_ROOT
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{"additional_context": "%s"}\n' "$session_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  printf '{"hookSpecificOutput": {"hookEventName": "SessionStart", "additionalContext": "%s"}}\n' "$session_context"
else
  printf '{"additionalContext": "%s"}\n' "$session_context"
fi

exit 0
