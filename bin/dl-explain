#!/usr/bin/env bash
# dl-explain — Query the codebase knowledge graph via codebase-memory-mcp
# Usage:
#   dl-explain <query>              — search for a symbol/concept
#   dl-explain --rank [--budget N]  — top N nodes by degree
#   dl-explain --diff HEAD~5 HEAD   — what changed between commits
#   dl-explain --node <file>        — node for a file + 1 level edges
#   dl-explain --impact             — detect_changes blast radius
#   dl-explain --dead-code          — find zero-caller functions
#   dl-explain --clones             — find near-clone pairs
# Options:
#   --project <name>                — scope to a specific project (orchestrator mode)
#   --headless                      — non-interactive mode

set -euo pipefail

if [[ "${1:-}" == "--version" || "${1:-}" == "-v" ]]; then
  _SCRIPT_SOURCE="${BASH_SOURCE[0]}"
  while [ -L "$_SCRIPT_SOURCE" ]; do
    _SCRIPT_DIR_INNER="$(cd "$(dirname "$_SCRIPT_SOURCE")" && pwd)"
    _SCRIPT_SOURCE="$(readlink "$_SCRIPT_SOURCE")"
    [[ "$_SCRIPT_SOURCE" != /* ]] && _SCRIPT_SOURCE="$_SCRIPT_DIR_INNER/$_SCRIPT_SOURCE"
  done
  _SCRIPT_DIR_INNER="$(cd "$(dirname "$_SCRIPT_SOURCE")" && pwd)"
  _VER=$(node -p "require(\"$_SCRIPT_DIR_INNER/../package.json\").version" 2>/dev/null || echo "unknown")
  echo "Devline dl-explain $_VER"
  exit 0
fi

PROJECT=""
BUDGET=512
HEADLESS=false
ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --project) PROJECT="$2"; shift 2 ;;
    --budget) BUDGET="$2"; shift 2 ;;
    --headless) HEADLESS=true; shift ;;
    *) ARGS+=("$1"); shift ;;
  esac
done

# --- Git root and .devline/ detection ---
GIT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || {
  echo "Not a git repo" >&2; exit 1
}

DEVLINE_DIR="$GIT_ROOT/.devline"

# If .devline/ doesn't exist and we're not in mock mode, exit silently (CI mode)
if [ ! -d "$DEVLINE_DIR" ] && [ "${DEVLINE_MCP_MOCK:-}" != "1" ]; then
  exit 0
fi

# Auto-detect project name from git root if not specified via --project
# MCP project names are derived by stripping the leading / and replacing / with -
if [ -z "$PROJECT" ]; then
  PROJECT=$(echo "$GIT_ROOT" | sed 's|^/||; s|/|-|g')
fi

PROJECT_ARG="\"project\":\"$PROJECT\","

check_mcp() {
  # DEVLINE_MCP_MOCK=1 skips real MCP calls (for tests)
  if [ "${DEVLINE_MCP_MOCK:-}" = "1" ]; then return 0; fi
  command -v codebase-memory-mcp &>/dev/null || {
    echo "Error: codebase-memory-mcp not found. Install with: dl-install --mcp" >&2
    exit 1
  }
}

# Mock MCP responder for tests
mock_mcp() {
  # Returns minimal valid responses for each query type
  case "${1:-}" in
    search_graph) echo '{"total":1,"results":[{"name":"MockNode","label":"Function","file_path":"mock.js","in_degree":0,"out_degree":0,"degree":1}],"has_more":false}' ;;
    trace_call_path) echo '{"paths":[]}' ;;
    trace_path) echo '{"paths":[["MockCaller","MockNode"]]}' ;;
    detect_changes) echo '{"affected_symbols":[{"name":"MockSymbol","file":"mock.js","risk":"high"}]}' ;;
    query_graph) echo '{"rows":[]}' ;;
    get_architecture) echo '{}' ;;
    search_code) echo '{"results":[],"raw_matches":[],"total_results":0,"raw_match_count":0}' ;;
    get_code_snippet) echo '{"snippet":"# mock snippet\nfunction mock() {}","file_path":"mock.js","start_line":1,"end_line":2}' ;;
    *) echo '{}' ;;
  esac
}

mcp_call() {
  local tool="$1"; shift
  if [ "${DEVLINE_MCP_MOCK:-}" = "1" ]; then
    mock_mcp "$tool"
  else
    codebase-memory-mcp cli "$tool" "$@"
  fi
}

MODE="${ARGS[0]:-search}"

case "$MODE" in
  --rank)
    check_mcp
    mcp_call search_graph \
      "{${PROJECT_ARG}\"limit\":$BUDGET,\"min_degree\":1}" \
      | python3 -c "
import json,sys
data=json.load(sys.stdin)
nodes=data.get('results',data) if isinstance(data,dict) else data
for n in nodes:
  print(f\"{n.get('name','?')} [{n.get('label','?')}] — {n.get('file','')} (degree: {n.get('degree',0)})\")
"
    ;;

  --diff)
    check_mcp
    FROM="${ARGS[1]:-HEAD~1}"
    TO="${ARGS[2]:-HEAD}"
    mcp_call detect_changes \
      "{${PROJECT_ARG}\"from_ref\":\"$FROM\",\"to_ref\":\"$TO\"}" | python3 -c "
import json,sys
data=json.load(sys.stdin)
symbols=data.get('affected_symbols',[])
print(f'Affected symbols: {len(symbols)}')
for s in symbols:
  risk=s.get('risk','unknown')
  print(f'  [{risk.upper()}] {s.get(\"name\",\"?\")} — {s.get(\"file\",\"\")}')" \
      2>/dev/null || echo "(diff query not supported in this version)"
    ;;

  --node)
    check_mcp
    if [ ${#ARGS[@]} -lt 2 ]; then
      echo "Usage: dl-explain --node <file>" >&2
      exit 1
    fi
    FILE="${ARGS[1]}"
    mcp_call search_graph \
      "{${PROJECT_ARG}\"file_pattern\":\"$FILE\",\"limit\":20}" | python3 -c "
import json,sys
data=json.load(sys.stdin)
nodes=data.get('results',data) if isinstance(data,dict) else data
for n in nodes:
  print(f\"{n.get('name','?')} [{n.get('label','?')}] — {n.get('file','')}\")"
    echo "--- Outbound ---"
    BASENAME=$(basename "${ARGS[1]}" | sed 's/\.[^.]*$//')
    # Two-step: resolve exact name via search_graph, then call trace_path
    RESOLVED_NAME=$(mcp_call search_graph \
      "{${PROJECT_ARG}\"name_pattern\":\".*${BASENAME}.*\",\"limit\":1}" 2>/dev/null \
      | python3 -c "
import json,sys
data=json.load(sys.stdin)
nodes=data.get('results',data) if isinstance(data,dict) else data
print(nodes[0].get('name','') if nodes else '')" 2>/dev/null || echo "")
    if [ -n "$RESOLVED_NAME" ]; then
      mcp_call trace_path \
        "{${PROJECT_ARG}\"symbol_name\":\"$RESOLVED_NAME\",\"direction\":\"outbound\",\"depth\":1}" \
        2>/dev/null | python3 -c "
import json,sys
data=json.load(sys.stdin)
paths=data.get('paths',[])
for p in paths:
  print(f\"  {' → '.join(str(n) for n in p)}\")" 2>/dev/null || echo "  (no outbound paths)"
    else
      echo "  (symbol not found in graph)"
    fi
    echo "--- Inbound ---"
    if [ -n "$RESOLVED_NAME" ]; then
      mcp_call trace_path \
        "{${PROJECT_ARG}\"symbol_name\":\"$RESOLVED_NAME\",\"direction\":\"inbound\",\"depth\":1}" \
        2>/dev/null | python3 -c "
import json,sys
data=json.load(sys.stdin)
paths=data.get('paths',[])
for p in paths:
  print(f\"  {' → '.join(str(n) for n in p)}\")" 2>/dev/null || echo "  (no inbound paths)"
    else
      echo "  (symbol not found in graph)"
    fi
    ;;

  --impact)
    check_mcp
    mcp_call detect_changes "{\"project\":\"$PROJECT\"}" | python3 -c "
import json,sys
data=json.load(sys.stdin)
symbols=data.get('affected_symbols',[])
print(f'Affected symbols: {len(symbols)}')
for s in symbols:
  risk=s.get('risk','unknown')
  print(f'  [{risk.upper()}] {s.get(\"name\",\"?\")} — {s.get(\"file\",\"\")}')"
    ;;

  --dead-code)
    check_mcp
    mcp_call query_graph \
      "{${PROJECT_ARG}\"query\":\"MATCH (f:Function) WHERE NOT ()-[:CALLS]->(f) AND NOT f.name STARTS WITH 'test' RETURN f.name, f.file LIMIT 50\"}" | python3 -c "
import json,sys
data=json.load(sys.stdin)
rows=data.get('rows',[])
print(f'Dead code candidates: {len(rows)}')
for r in rows:
  print(f'  {r.get(\"f.name\",\"?\")} — {r.get(\"f.file\",\"\")}')"
    ;;

  --clones)
    check_mcp
    mcp_call query_graph \
      "{${PROJECT_ARG}\"query\":\"MATCH (a)-[r:SIMILAR_TO]->(b) WHERE r.score > 0.8 RETURN a.name, b.name, r.score ORDER BY r.score DESC LIMIT 20\"}" | python3 -c "
import json,sys
data=json.load(sys.stdin)
rows=data.get('rows',[])
print(f'Near-clone pairs (score > 0.8): {len(rows)}')
for r in rows:
  print(f'  {r.get(\"a.name\",\"?\")} ≈ {r.get(\"b.name\",\"?\")} (score: {r.get(\"r.score\",0):.2f})')"
    ;;

  --help|-h)
    sed -n '2,12p' "$0"
    ;;

  --snippet)
    check_mcp
    SNIP_FILE="${ARGS[1]:-}"
    SNIP_START="${ARGS[2]:-1}"
    SNIP_END="${ARGS[3]:-10}"
    if [ -z "$SNIP_FILE" ]; then
      echo "Usage: dl-explain --snippet <file> <start_line> <end_line>" >&2
      exit 1
    fi
    mcp_call get_code_snippet \
      "{${PROJECT_ARG}\"file_path\":\"$SNIP_FILE\",\"start_line\":$SNIP_START,\"end_line\":$SNIP_END}" \
      2>/dev/null | python3 -c "
import json,sys
data=json.load(sys.stdin)
snippet=data.get('snippet','')
if snippet:
  print(snippet)
else:
  print('(no snippet returned)')" 2>/dev/null || echo "(snippet not available)"
    ;;

  *)
    # Default: semantic + structural search for query term
    check_mcp
    QUERY="$MODE"
    echo "=== Structural search: $QUERY ==="
    SEARCH_RESULT=$(mcp_call search_graph \
      "{${PROJECT_ARG}\"name_pattern\":\".*${QUERY}.*\",\"limit\":20}" 2>/dev/null || echo '{"results":[]}')
    RESULT_COUNT=$(echo "$SEARCH_RESULT" | python3 -c "
import json,sys
data=json.load(sys.stdin)
nodes=data.get('results',data) if isinstance(data,dict) else data
print(len(nodes))" 2>/dev/null || echo "0")
    if [ "$RESULT_COUNT" -gt 0 ]; then
      echo "$SEARCH_RESULT" | python3 -c "
import json,sys
data=json.load(sys.stdin)
nodes=data.get('results',data) if isinstance(data,dict) else data
for n in nodes:
  print(f\"  {n.get('name','?')} [{n.get('label','?')}] — {n.get('file','')}\")"
    else
      # Retry with label:Section (catches markdown/docs repos)
      SECTION_RESULT=$(mcp_call search_graph \
        "{${PROJECT_ARG}\"name_pattern\":\".*${QUERY}.*\",\"label\":\"Section\",\"limit\":20}" 2>/dev/null || echo '{"results":[]}')
      SECTION_COUNT=$(echo "$SECTION_RESULT" | python3 -c "
import json,sys
data=json.load(sys.stdin)
nodes=data.get('results',data) if isinstance(data,dict) else data
print(len(nodes))" 2>/dev/null || echo "0")
      if [ "$SECTION_COUNT" -gt 0 ]; then
        echo "$SECTION_RESULT" | python3 -c "
import json,sys
data=json.load(sys.stdin)
nodes=data.get('results',data) if isinstance(data,dict) else data
for n in nodes:
  print(f\"  {n.get('name','?')} [{n.get('label','?')}] — {n.get('file','')}\")"
      else
        # Try search_code before falling back to grep
        CODE_RESULT=$(mcp_call search_code \
          "{${PROJECT_ARG}\"pattern\":\"$QUERY\"}" 2>/dev/null || echo '{"results":[]}')
        CODE_COUNT=$(echo "$CODE_RESULT" | python3 -c "
import json,sys
data=json.load(sys.stdin)
results=data.get('results',data.get('raw_matches',[]))
print(len(results))" 2>/dev/null || echo "0")
        if [ "$CODE_COUNT" -gt 0 ]; then
          echo "$CODE_RESULT" | python3 -c "
import json,sys
data=json.load(sys.stdin)
results=data.get('results',data.get('raw_matches',[]))
for r in results:
  print(f\"  {r}\")"
        else
          # Final fallback: grep
          echo "  (no graph results — falling back to grep)"
          grep -rnF "$QUERY" "$GIT_ROOT" --include='*.js' --include='*.ts' --include='*.py' --include='*.sh' \
            -l 2>/dev/null | head -10 | while read -r f; do echo "  $f"; done || true
        fi
      fi
    fi
    echo ""
    echo "=== Call paths: $QUERY ==="
    # Two-step: resolve exact name via search_graph, then call trace_path
    TRACE_NAME=$(echo "$SEARCH_RESULT" | python3 -c "
import json,sys
data=json.load(sys.stdin)
nodes=data.get('results',data) if isinstance(data,dict) else data
print(nodes[0].get('name','') if nodes else '')" 2>/dev/null || echo "")
    if [ -n "$TRACE_NAME" ]; then
      mcp_call trace_path \
        "{${PROJECT_ARG}\"symbol_name\":\"$TRACE_NAME\",\"direction\":\"both\",\"depth\":2}" \
        2>/dev/null | python3 -c "
import json,sys
data=json.load(sys.stdin)
paths=data.get('paths',[])
for p in paths:
  print(f\"  {' → '.join(str(n) for n in p)}\")
" 2>/dev/null || echo "  (no call paths found)"
    else
      echo "  (no call paths found)"
    fi
    ;;
esac
