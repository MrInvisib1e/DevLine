#!/usr/bin/env bash
# df-install — One-command DevFlow installation
# Usage: df-install [--platform claude|opencode|gemini|cursor|all] [--install-dir <path>] [--dry-run]
#
# By default installs for all detected platforms.
# Run from the DevFlow repo directory, or from anywhere after cloning to ~/.devflow.

set -euo pipefail

# ── colour helpers ─────────────────────────────────────────────────────────────
if [[ -t 1 ]]; then
  RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
  BLUE='\033[0;34m'; BOLD='\033[1m'; RESET='\033[0m'
else
  RED=''; GREEN=''; YELLOW=''; BLUE=''; BOLD=''; RESET=''
fi

ok()   { printf "${GREEN}✓${RESET} %s\n" "$*"; }
info() { printf "${BLUE}→${RESET} %s\n" "$*"; }
warn() { printf "${YELLOW}!${RESET} %s\n" "$*"; }
err()  { printf "${RED}✗${RESET} %s\n" "$*" >&2; }
header() { printf "\n${BOLD}%s${RESET}\n" "$*"; }

# ── flags ─────────────────────────────────────────────────────────────────────
DRY_RUN=false
PLATFORM="all"
INSTALL_DIR=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run)         DRY_RUN=true; shift ;;
    --platform)        PLATFORM="${2:-all}"; shift 2 ;;
    --install-dir)     INSTALL_DIR="${2:-}"; shift 2 ;;
    -h|--help)
      echo "Usage: df-install [--platform claude|opencode|gemini|all] [--install-dir <path>] [--dry-run]"
      exit 0 ;;
    *) shift ;;
  esac
done

# ── helpers ───────────────────────────────────────────────────────────────────
run() {
  if [[ "$DRY_RUN" == true ]]; then
    info "[dry-run] $*"
  else
    eval "$@"
  fi
}

# Safely update a JSON file using python3 (more reliable than jq for nested upserts)
json_upsert_plugin() {
  local json_file="$1"
  local plugin_key="$2"   # e.g. "devflow@local"
  local install_path="$3"
  local version="$4"

  local now
  now=$(date -u +"%Y-%m-%dT%H:%M:%S.000Z")

  # If file doesn't exist, create skeleton
  if [[ ! -f "$json_file" ]]; then
    echo '{"version": 2, "plugins": {}}' > "$json_file"
  fi

  python3 - <<PYEOF
import json, sys

with open('${json_file}', 'r') as f:
    data = json.load(f)

if 'plugins' not in data:
    data['plugins'] = {}

entry = [{
    "scope": "user",
    "installPath": "${install_path}",
    "version": "${version}",
    "installedAt": "${now}",
    "lastUpdated": "${now}",
    "gitCommitSha": "local"
}]

data['plugins']['${plugin_key}'] = entry

with open('${json_file}', 'w') as f:
    json.dump(data, f, indent=2)
    f.write('\n')

print("ok")
PYEOF
}

# Append a block to a file only if a marker string is not already present
append_if_missing() {
  local file="$1"
  local marker="$2"
  local content="$3"

  if [[ -f "$file" ]] && grep -qF "$marker" "$file" 2>/dev/null; then
    return 0   # already present
  fi
  printf '%s\n' "$content" >> "$file"
}

# ── locate DevFlow root ────────────────────────────────────────────────────────
# Determine where the DevFlow repo lives.
# Priority: --install-dir > current script's parent > ~/.devflow
SCRIPT_PATH="$(cd "$(dirname "$0")" && pwd)"
DEVFLOW_ROOT="$(cd "${SCRIPT_PATH}/.." && pwd)"

if [[ -n "$INSTALL_DIR" ]]; then
  DEVFLOW_ROOT="$INSTALL_DIR"
elif [[ ! -f "${DEVFLOW_ROOT}/skills/using-devflow/SKILL.md" ]]; then
  # Not in the repo — try ~/.devflow
  if [[ -f "${HOME}/.devflow/skills/using-devflow/SKILL.md" ]]; then
    DEVFLOW_ROOT="${HOME}/.devflow"
  else
    err "Cannot find DevFlow repo. Run from the DevFlow directory, or pass --install-dir <path>."
    exit 1
  fi
fi

DEVFLOW_VERSION="$(jq -r '.version // "3.0.0"' "${DEVFLOW_ROOT}/package.json" 2>/dev/null || echo "3.0.0")"

header "DevFlow ${DEVFLOW_VERSION} — Installer"
info "DevFlow root: ${DEVFLOW_ROOT}"
[[ "$DRY_RUN" == true ]] && warn "Dry-run mode — no changes will be made"

# ── prerequisites check ───────────────────────────────────────────────────────
header "Checking prerequisites"

missing_prereqs=()
for cmd in git jq sqlite3; do
  if command -v "$cmd" >/dev/null 2>&1; then
    ok "$cmd"
  else
    err "$cmd — missing"
    missing_prereqs+=("$cmd")
  fi
done

if [[ ${#missing_prereqs[@]} -gt 0 ]]; then
  err "Install missing prerequisites first: ${missing_prereqs[*]}"
  if [[ "$(uname)" == "Darwin" ]]; then
    info "Hint: brew install ${missing_prereqs[*]}"
  fi
  exit 1
fi

# ── Step 1: Add bin/ to PATH ───────────────────────────────────────────────────
header "Step 1 — Shell PATH"

BIN_DIR="${DEVFLOW_ROOT}/bin"
PATH_LINE="export PATH=\"${BIN_DIR}:\$PATH\"  # DevFlow"

# Detect shell rc file
SHELL_RC=""
case "${SHELL:-}" in
  */zsh)  SHELL_RC="${HOME}/.zshrc" ;;
  */bash) SHELL_RC="${HOME}/.bashrc" ;;
  *)
    if [[ -f "${HOME}/.zshrc" ]]; then
      SHELL_RC="${HOME}/.zshrc"
    elif [[ -f "${HOME}/.bashrc" ]]; then
      SHELL_RC="${HOME}/.bashrc"
    fi
    ;;
esac

# Check if already on PATH
if echo "${PATH}" | tr ':' '\n' | grep -qxF "${BIN_DIR}"; then
  ok "bin/ already on PATH"
else
  if [[ -n "$SHELL_RC" ]]; then
    if [[ "$DRY_RUN" == true ]]; then
      info "[dry-run] Would append to ${SHELL_RC}: ${PATH_LINE}"
    else
      append_if_missing "$SHELL_RC" "DevFlow" "$PATH_LINE"
      ok "Added ${BIN_DIR} to PATH in ${SHELL_RC}"
      warn "Run: source ${SHELL_RC}  (or restart terminal for PATH to take effect)"
    fi
  else
    warn "Could not detect shell rc file — add this manually:"
    warn "  ${PATH_LINE}"
  fi
fi

# Also add to current session
export PATH="${BIN_DIR}:${PATH}"

# ── Step 2: Platform-specific install ─────────────────────────────────────────

install_claude_code() {
  header "Step 2 — Claude Code"

  CLAUDE_DIR="${HOME}/.claude"
  CLAUDE_PLUGINS_DIR="${CLAUDE_DIR}/plugins"
  PLUGINS_JSON="${CLAUDE_PLUGINS_DIR}/installed_plugins.json"
  CACHE_DIR="${CLAUDE_PLUGINS_DIR}/cache/local"
  SYMLINK="${CACHE_DIR}/devflow"
  CLAUDE_MD="${CLAUDE_DIR}/CLAUDE.md"

  # 2a. Create symlink in Claude plugin cache
  if [[ ! -d "$CACHE_DIR" ]]; then
    run "mkdir -p '${CACHE_DIR}'"
    ok "Created ${CACHE_DIR}"
  fi

  if [[ -L "$SYMLINK" && "$(readlink "$SYMLINK")" == "$DEVFLOW_ROOT" ]]; then
    ok "Symlink already correct: ${SYMLINK} → ${DEVFLOW_ROOT}"
  else
    if [[ -e "$SYMLINK" ]]; then
      run "rm -f '${SYMLINK}'"
    fi
    run "ln -s '${DEVFLOW_ROOT}' '${SYMLINK}'"
    ok "Created symlink: ${SYMLINK} → ${DEVFLOW_ROOT}"
  fi

  # 2b. Register in installed_plugins.json
  if [[ "$DRY_RUN" == true ]]; then
    info "[dry-run] Would upsert devflow@local into ${PLUGINS_JSON}"
  else
    mkdir -p "$CLAUDE_PLUGINS_DIR"
    result=$(json_upsert_plugin "$PLUGINS_JSON" "devflow@local" "$SYMLINK" "$DEVFLOW_VERSION")
    if [[ "$result" == "ok" ]]; then
      ok "Registered devflow@local in ${PLUGINS_JSON}"
    else
      err "Failed to update ${PLUGINS_JSON}"
    fi
  fi

  # 2c. Update ~/.claude/CLAUDE.md with skill paths
  SKILL_TABLE="
# DevFlow

DevFlow is active in this session. Skills are available on demand.

## How to use skills

Load any DevFlow skill when relevant by referencing its path:

| Trigger | Skill file |
|---------|-----------|
| \`/init\` | \`${DEVFLOW_ROOT}/skills/init/SKILL.md\` |
| \`/feature <desc>\` | \`${DEVFLOW_ROOT}/skills/feature/SKILL.md\` |
| \`/fix <desc>\` | \`${DEVFLOW_ROOT}/skills/fix/SKILL.md\` |
| \`/review\` | \`${DEVFLOW_ROOT}/skills/review/SKILL.md\` |
| \`/plan <desc>\` | \`${DEVFLOW_ROOT}/skills/plan/SKILL.md\` |
| \`/mem-sync\` | \`${DEVFLOW_ROOT}/skills/mem-sync/SKILL.md\` |
| \`/verify\` | \`${DEVFLOW_ROOT}/skills/verify/SKILL.md\` |

Shell scripts are in \`${DEVFLOW_ROOT}/bin/\` — ensure that directory is on your PATH.

## Iron Law

Before any DevFlow operation: check for \`.devflow/\` in the git root. If absent, run \`/init\` first.
"

  if [[ "$DRY_RUN" == true ]]; then
    info "[dry-run] Would update ${CLAUDE_MD} with skill paths"
  else
    mkdir -p "$CLAUDE_DIR"

    # If CLAUDE.md already has DevFlow section, replace it; otherwise append
    if [[ -f "$CLAUDE_MD" ]] && grep -q "# DevFlow" "$CLAUDE_MD" 2>/dev/null; then
      # Replace the existing DevFlow block using python3
      python3 - <<PYEOF
import re

with open('${CLAUDE_MD}', 'r') as f:
    content = f.read()

new_block = '''${SKILL_TABLE}'''

# Split on all '# DevFlow' headings (handles duplicates from prior bad runs)
# parts[0] = content before first DevFlow block
# parts[1..] = each DevFlow block content (discarded)
parts = re.split(r'(?m)^# DevFlow\b', content)
non_devflow = parts[0].rstrip('\n')

if non_devflow:
    result = non_devflow + '\n\n' + new_block
else:
    result = new_block

with open('${CLAUDE_MD}', 'w') as f:
    f.write(result)
PYEOF
      ok "Updated DevFlow section in ${CLAUDE_MD}"
    else
      printf '%s\n' "$SKILL_TABLE" >> "$CLAUDE_MD"
      ok "Appended DevFlow section to ${CLAUDE_MD}"
    fi
  fi

  # 2d. Create slash command files in ~/.claude/commands/
  local COMMANDS_DIR="${CLAUDE_DIR}/commands"

  declare -A SKILL_DESCS=(
    [init]="initialize repo with knowledge graph"
    [feature]="implement a feature (PRD → slices → code)"
    [fix]="hypothesis-driven bug fix"
    [review]="architecture-aware code review"
    [plan]="generate implementation plan"
    [mem-sync]="sync knowledge graph with latest code changes"
    [verify]="verify work passes tests/build/lint before claiming complete"
  )

  if [[ "$DRY_RUN" == true ]]; then
    info "[dry-run] Would create slash commands in ${COMMANDS_DIR}/"
  else
    mkdir -p "$COMMANDS_DIR"

    for skill in init feature fix review plan; do
      local desc="${SKILL_DESCS[$skill]}"
      local cmd_file="${COMMANDS_DIR}/${skill}.md"
      local has_args=false
      [[ "$skill" == "feature" || "$skill" == "fix" || "$skill" == "plan" ]] && has_args=true

      cat > "$cmd_file" <<CMDF
---
description: DevFlow — ${desc}
---
Load and follow the DevFlow ${skill} skill from: ${DEVFLOW_ROOT}/skills/${skill}/SKILL.md
$(${has_args} && echo -e "\nTask: \$ARGUMENTS" || true)
CMDF
    done

    # mem-sync and verify — no arguments
    for skill in mem-sync verify; do
      local desc="${SKILL_DESCS[$skill]}"
      cat > "${COMMANDS_DIR}/${skill}.md" <<CMDF
---
description: DevFlow — ${desc}
---
Load and follow the DevFlow ${skill} skill from: ${DEVFLOW_ROOT}/skills/${skill}/SKILL.md
CMDF
    done

    ok "Created slash commands in ${COMMANDS_DIR}/ (init, feature, fix, review, plan, mem-sync, verify)"
  fi

  ok "Claude Code installation complete"
  info "DevFlow commands visible in slash command autocomplete (/init, /feature, /fix, /review, /plan, /mem-sync, /verify)"
  info "Bootstrap skill injected at every session start"
}

install_opencode() {
  header "Step 2 — OpenCode"

  # Look for opencode.json in common locations
  OPENCODE_JSON=""
  for candidate in \
    "${HOME}/.config/opencode/opencode.json" \
    "${HOME}/.opencode.json" \
    "$(pwd)/opencode.json"; do
    if [[ -f "$candidate" ]]; then
      OPENCODE_JSON="$candidate"
      break
    fi
  done

  local PLUGIN_ENTRY="devflow@git+file://${DEVFLOW_ROOT}"

  if [[ -z "$OPENCODE_JSON" ]]; then
    warn "opencode.json not found. Creating at ~/.config/opencode/opencode.json"
    OPENCODE_JSON="${HOME}/.config/opencode/opencode.json"
    if [[ "$DRY_RUN" != true ]]; then
      mkdir -p "$(dirname "$OPENCODE_JSON")"
      echo '{"plugin": []}' > "$OPENCODE_JSON"
    fi
  fi

  if [[ "$DRY_RUN" == true ]]; then
    info "[dry-run] Would add ${PLUGIN_ENTRY} to plugin array in ${OPENCODE_JSON}"
  else
    # Add to plugin array if not already present
    python3 - <<PYEOF
import json

with open('${OPENCODE_JSON}', 'r') as f:
    data = json.load(f)

if 'plugin' not in data:
    data['plugin'] = []

entry = '${PLUGIN_ENTRY}'
if entry not in data['plugin']:
    data['plugin'].append(entry)

with open('${OPENCODE_JSON}', 'w') as f:
    json.dump(data, f, indent=2)
    f.write('\n')

print("ok")
PYEOF
    ok "Added DevFlow to ${OPENCODE_JSON}"
  fi

  ok "OpenCode installation complete"
  info "OpenCode will inject the DevFlow bootstrap automatically"
}

install_gemini() {
  header "Step 2 — Gemini CLI"

  warn "Gemini CLI installation requires the repo to be publicly hosted."
  info "Once the repo is public, run:"
  printf "  gemini extensions install %s\n" "https://github.com/<your-username>/Development-Flow"
  printf "\n"

  # For local dev: add GEMINI.md reference manually
  GEMINI_MD_SRC="${DEVFLOW_ROOT}/GEMINI.md"
  LOCAL_GEMINI="${HOME}/.gemini/GEMINI.md"
  if [[ -f "$GEMINI_MD_SRC" ]]; then
    if [[ "$DRY_RUN" == true ]]; then
      info "[dry-run] Would append DevFlow reference to ${LOCAL_GEMINI}"
    else
      mkdir -p "$(dirname "$LOCAL_GEMINI")"
      append_if_missing "$LOCAL_GEMINI" "using-devflow" "@${DEVFLOW_ROOT}/skills/using-devflow/SKILL.md"
      ok "Added DevFlow bootstrap reference to ${LOCAL_GEMINI}"
    fi
  fi
}

# ── Platform dispatch ──────────────────────────────────────────────────────────
case "$PLATFORM" in
  claude)
    install_claude_code
    ;;
  opencode)
    install_opencode
    ;;
  gemini)
    install_gemini
    ;;
  all)
    # Claude Code — always try (most common)
    if [[ -d "${HOME}/.claude" ]] || command -v claude >/dev/null 2>&1; then
      install_claude_code
    else
      info "Skipping Claude Code (not detected)"
    fi

    # OpenCode — try if config exists or opencode binary found
    if command -v opencode >/dev/null 2>&1 \
       || [[ -f "${HOME}/.config/opencode/opencode.json" ]] \
       || [[ -f "${HOME}/.opencode.json" ]]; then
      install_opencode
    else
      info "Skipping OpenCode (not detected)"
    fi

    # Gemini — only if gemini binary found
    if command -v gemini >/dev/null 2>&1; then
      install_gemini
    else
      info "Skipping Gemini CLI (not detected)"
    fi
    ;;
  *)
    err "Unknown platform: ${PLATFORM}. Use: claude, opencode, gemini, or all"
    exit 1
    ;;
esac

# ── Step 3: Verify ─────────────────────────────────────────────────────────────
header "Verification"

if command -v df-explain >/dev/null 2>&1; then
  ok "df-explain found on PATH"
else
  warn "df-explain not on PATH yet — restart terminal or: source ${SHELL_RC:-~/.zshrc}"
fi

if command -v df-sync >/dev/null 2>&1; then
  ok "df-sync found on PATH"
fi

header "Done"
printf "${GREEN}${BOLD}DevFlow ${DEVFLOW_VERSION} installed successfully.${RESET}\n"
printf "\n"
printf "Next steps:\n"
printf "  1. %s\n" "Restart your terminal (or: source ${SHELL_RC:-~/.zshrc})"
printf "  2. %s\n" "Open any git repository in Claude Code"
printf "  3. %s\n" "Type: /init"
printf "\n"
