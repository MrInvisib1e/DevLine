#!/usr/bin/env bash
set -euo pipefail

# ─── constants ────────────────────────────────────────────────────────────────

DEVFLOW_VERSION="0.1.0"

# ─── helpers ──────────────────────────────────────────────────────────────────

err() { echo "[DevFlow] $*" >&2; }

check_prereqs() {
  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    err "Not a git repo."
    exit 1
  fi
  if ! command -v jq >/dev/null 2>&1; then
    err "Missing prerequisite: jq"
    exit 1
  fi
}

atomic_write() {
  local file="$1" content="$2"
  local tmp="${file}.tmp"
  if [[ -e "$file" && ! -w "$file" ]]; then
    err "Cannot write to $file: permission denied"
    return 1
  fi
  printf '%s' "$content" > "$tmp"
  sync 2>/dev/null || true
  mv "$tmp" "$file"
}

# ─── memory → markdown ────────────────────────────────────────────────────────

memory_to_markdown() {
  local memory_file="$1"
  local last_synced runtime frontend test_cmd

  last_synced=$(jq -r '.last_synced // "unknown"' "$memory_file")
  runtime=$(jq -r '.stack.runtime // "unknown"' "$memory_file")
  frontend=$(jq -r '.stack.frontend // "none"' "$memory_file")
  test_cmd=$(jq -r '.stack.test_cmd // "unknown"' "$memory_file")

  printf '# DevFlow Memory\n\n'
  printf '<!-- Auto-generated by df-export. Last synced: %s -->\n\n' "$last_synced"

  printf '## Stack\n\n'
  printf -- '- **Runtime:** %s\n' "$runtime"
  printf -- '- **Frontend:** %s\n' "$frontend"
  # shellcheck disable=SC2016
  printf -- '- **Test command:** `%s`\n' "$test_cmd"

  local deps
  deps=$(jq -r '.stack.key_dependencies // [] | .[]' "$memory_file" 2>/dev/null || true)
  if [[ -n "$deps" ]]; then
    printf -- '- **Key dependencies:** '
    printf '%s' "$deps" | tr '\n' ',' | sed 's/,$//'
    printf '\n'
  fi

  printf '\n## Architecture\n\n'

  local layers
  layers=$(jq -r '.architecture.layers // [] | .[]' "$memory_file" 2>/dev/null || true)
  if [[ -n "$layers" ]]; then
    printf '**Layers:** %s\n\n' "$(printf '%s' "$layers" | tr '\n' ',' | sed 's/,$//')"
  fi

  local patterns
  patterns=$(jq -r '.architecture.patterns // [] | .[]' "$memory_file" 2>/dev/null || true)
  if [[ -n "$patterns" ]]; then
    printf '**Patterns:**\n'
    while IFS= read -r p; do
      printf -- '- %s\n' "$p"
    done <<< "$patterns"
    printf '\n'
  fi

  local folder_struct
  folder_struct=$(jq -r '.architecture.folder_structure // {} | to_entries[] | "- `\(.key)`: \(.value)"' "$memory_file" 2>/dev/null || true)
  if [[ -n "$folder_struct" ]]; then
    printf '**Folder structure:**\n'
    printf '%s\n' "$folder_struct"
    printf '\n'
  fi

  printf '## Conventions\n\n'

  local naming
  naming=$(jq -r '.conventions.naming // [] | .[]' "$memory_file" 2>/dev/null || true)
  if [[ -n "$naming" ]]; then
    printf '**Naming:**\n'
    while IFS= read -r n; do
      printf -- '- %s\n' "$n"
    done <<< "$naming"
    printf '\n'
  fi

  local anti
  anti=$(jq -r '.conventions.anti_patterns // [] | .[]' "$memory_file" 2>/dev/null || true)
  if [[ -n "$anti" ]]; then
    printf '**Anti-patterns (avoid):**\n'
    while IFS= read -r a; do
      printf -- '- %s\n' "$a"
    done <<< "$anti"
    printf '\n'
  fi
}

# ─── commands ─────────────────────────────────────────────────────────────────

cmd_version() {
  echo "DevFlow $DEVFLOW_VERSION"
  exit 0
}

cmd_export() {
  local format="${1:-markdown}"
  local output_file="${2:-}"

  check_prereqs

  # CI mode: no .devflow/ → exit 0 silently
  local devflow_dir
  devflow_dir="$(git rev-parse --show-toplevel)/.devflow"
  if [[ ! -d "$devflow_dir" ]]; then
    exit 0
  fi

  local memory_file="${devflow_dir}/active/memory.json"
  if [[ ! -f "$memory_file" ]]; then
    err "memory.json not found. Memory not initialised — run df-init first."
    exit 1
  fi

  local content
  if [[ "$format" == "json" ]]; then
    content=$(cat "$memory_file")
  else
    content=$(memory_to_markdown "$memory_file")
  fi

  if [[ -n "$output_file" ]]; then
    atomic_write "$output_file" "$content"
    echo "[DevFlow] Exported to $output_file"
  else
    printf '%s\n' "$content"
  fi
}

cmd_snapshot() {
  check_prereqs

  local devflow_dir
  devflow_dir="$(git rev-parse --show-toplevel)/.devflow"
  if [[ ! -d "$devflow_dir" ]]; then
    exit 0
  fi

  local active_dir="${devflow_dir}/active"
  local timestamp
  timestamp=$(date -u '+%Y-%m-%dT%H-%M-%SZ')
  local snapshot_dir="${devflow_dir}/snapshots/${timestamp}"

  mkdir -p "$snapshot_dir"

  for f in memory.json nodes.json edges.json memory.md; do
    if [[ -f "${active_dir}/${f}" ]]; then
      cp "${active_dir}/${f}" "${snapshot_dir}/${f}"
    fi
  done

  echo "[DevFlow] Snapshot created: $timestamp"
}

cmd_restore() {
  local snapshot_name="$1"
  check_prereqs

  local devflow_dir
  devflow_dir="$(git rev-parse --show-toplevel)/.devflow"
  local snapshot_dir="${devflow_dir}/snapshots/${snapshot_name}"

  if [[ ! -d "$snapshot_dir" ]]; then
    err "Snapshot \"$snapshot_name\" not found in .devflow/snapshots/."
    exit 1
  fi

  local active_dir="${devflow_dir}/active"

  for f in memory.json nodes.json edges.json memory.md; do
    if [[ -f "${snapshot_dir}/${f}" ]]; then
      cp "${snapshot_dir}/${f}" "${active_dir}/${f}"
    fi
  done

  echo "[DevFlow] Restored from snapshot: $snapshot_name"
}

# ─── dispatch ─────────────────────────────────────────────────────────────────

FORMAT="markdown"
OUTPUT_FILE=""
SNAPSHOT=false
RESTORE_NAME=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --version) cmd_version ;;
    --format)
      shift
      FORMAT="${1:-markdown}"
      shift
      ;;
    --output)
      shift
      OUTPUT_FILE="${1:-}"
      shift
      ;;
    --snapshot)
      SNAPSHOT=true
      shift
      ;;
    --restore)
      shift
      RESTORE_NAME="${1:-}"
      shift
      ;;
    *)
      err "Unknown flag: $1"
      exit 1
      ;;
  esac
done

if [[ "$SNAPSHOT" == true ]]; then
  cmd_snapshot
elif [[ -n "$RESTORE_NAME" ]]; then
  cmd_restore "$RESTORE_NAME"
else
  cmd_export "$FORMAT" "$OUTPUT_FILE"
fi
