{
  "name": "@reydo/devline",
  "version": "0.6.6",
  "description": "Skill library that makes AI coding assistants behave like senior engineers",
  "type": "module",
  "main": ".opencode/plugins/devline.js",
  "bin": {
    "devline": "./bin/devline",
    "dl": "./bin/dl",
    "dl-init": "./bin/dl-init",
    "dl-install": "./bin/dl-install.mjs",
    "dl-explain": "./bin/dl-explain",
    "dl-check": "./bin/dl-check",
    "dl-test": "./bin/dl-test",
    "dl-workspace": "./bin/dl-workspace",
    "dl-benchmark": "./bin/dl-benchmark",
    "dl-update": "./bin/dl-update.mjs",
    "dl-log": "./bin/dl-log"
  },
  "files": [
    "bin/",
    "lib/",
    "skills/",
    "hooks/",
    ".claude-plugin/",
    ".cursor-plugin/",
    ".opencode/",
    "gemini-extension.json",
    "GEMINI.md",
    ".codex/"
  ],
  "scripts": {
    "test": "node --test tests/installer/*.test.mjs",
    "version": "node scripts/sync-version.js && git add .claude-plugin/plugin.json .cursor-plugin/plugin.json gemini-extension.json"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MrInvisib1e/devline.git"
  },
  "homepage": "https://github.com/MrInvisib1e/devline",
  "license": "MIT",
  "devline": {
    "skills_dir": "./skills",
    "bootstrap_skill": "using-devline",
    "mcp_server": "codebase-memory-mcp"
  }
}
