{
  "name": "@devflow/skills",
  "version": "4.0.0",
  "description": "DevFlow — generic AI development workflow powered by codebase-memory-mcp",
  "type": "module",
  "main": ".opencode/plugins/devflow.js",
  "bin": {
    "devflow":      "./bin/devflow",
    "df":           "./bin/df",
    "df-init":      "./bin/df-init",
    "df-explain":   "./bin/df-explain",
    "df-test":      "./bin/df-test",
    "df-workspace": "./bin/df-workspace",
    "df-install":   "./bin/df-install",
    "df-check":     "./bin/df-check",
    "df-benchmark": "./bin/df-benchmark"
  },
  "files": [
    "bin/",
    "skills/",
    "hooks/",
    ".claude-plugin/",
    ".cursor-plugin/",
    ".opencode/",
    "gemini-extension.json",
    "GEMINI.md",
    ".codex/"
  ],
  "keywords": ["ai", "developer-tools", "claude", "opencode", "skills", "codebase-memory-mcp"],
  "engines": {
    "node": ">=18.0.0"
  },
  "devflow": {
    "skills_dir": "./skills",
    "bootstrap_skill": "using-devflow",
    "mcp_server": "codebase-memory-mcp"
  }
